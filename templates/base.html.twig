<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Shop Admin{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        
        <style>
            body { background-color: #f8f9fa; }
            .sidebar { min-height: 100vh; background-color: #212529; color: white; }
            .sidebar a { color: #adbc9f; text-decoration: none; padding: 12px 20px; display: block; border-radius: 5px; margin-bottom: 5px; }
            .sidebar a:hover, .sidebar a.active { background-color: #343a40; color: white; }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-3 col-lg-2 sidebar p-3">
                    <h4 class="text-center my-3">🛒 My Shop</h4>
                    <hr class="text-secondary">
                    
                    <small class="text-muted d-block px-3 mb-2 text-uppercase fw-bold" style="font-size: 0.75rem;">Admin Panel</small>
                    <nav class="nav flex-column">
                        {# Dashboard (Ստուգում ենք ըստ ռոութի անվան, որ կատեգորիաները չխանգարեն) #}
                        <a href="{{ path('app_home') }}" class="{% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </a>
                        
                        {# Products CRUD #}
                        <a href="{{ path('app_product_index') }}" class="{% if 'product' in app.request.pathinfo %}active{% endif %}">
                            <i class="bi bi-box-seam me-2"></i> Products CRUD
                        </a>
                        
                        {# Categories #}
                        <a href="{{ path('app_category_index') }}" class="{% if 'category' in app.request.pathinfo %}active{% endif %}">
                            <i class="bi bi-tags me-2"></i> Categories
                        </a>
                        
                        {# Users #}
                        <a href="{{ path('app_user_index') }}" class="{% if 'user' in app.request.pathinfo %}active{% endif %}">
                            <i class="bi bi-people me-2"></i> Users
                        </a>
                        
                        {# Orders #}
                        <a href="{{ path('app_order_index') }}" class="{% if 'order' in app.request.pathinfo %}active{% endif %}">
                            <i class="bi bi-cart me-2"></i> Orders
                        </a>
                        
                        {# Statistics (Նույնպես ակտիվանում է, երբ գտնվում ենք գլխավոր էջում) #}
                        <a href="{{ path('app_home') }}" class="{% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}">
                            <i class="bi bi-bar-chart me-2"></i> Statistics
                        </a>
                    </nav>
                </div>

                <div class="col-md-9 col-lg-10 p-4">
                    <div class="card shadow-sm p-4 bg-white" style="border-radius: 10px;">
                        {% block body %}{% endblock %}
                    </div>
                </div>
            </div>
        </div>
        {% block javascripts %}{% endblock %}
    </body>
</html>