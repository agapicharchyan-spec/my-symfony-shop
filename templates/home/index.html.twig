{% extends 'base.html.twig' %}

{% block title %}Welcome to Our Shop!{% endblock %}

{% block body %}
{# Հաջողության հաղորդագրությունը ցուցադրելու համար #}
{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{% endfor %}

{# Գլխավոր Բաններ #}
<div class="row bg-dark text-white p-5 rounded mb-5 align-items-center shadow-sm">
    <div class="col-md-6">
        <h1 class="display-4 fw-bold">🌟 Our Awesome Shop</h1>
        <p class="lead">Discover the best products curated just for you with premium quality.</p>
    </div>
    <div class="col-md-6 text-end d-flex justify-content-end gap-2">
        <a href="{{ path('app_cart_index') }}" class="btn btn-outline-light btn-lg fw-bold shadow">
            <i class="bi bi-cart3"></i> View Cart
        </a>
        <a href="{{ path('app_product_index') }}" class="btn btn-warning btn-lg fw-bold shadow">
            <i class="bi bi-gear-fill"></i> Go to Admin Panel
        </a>
    </div>
</div>

{# ՎԻՃԱԿԱԳՐՈՒԹՅԱՆ ԲԼՈԿՆԵՐ #}
<div class="row g-3 mb-5">
    <div class="col-md-4">
        <div class="p-3 bg-primary text-white rounded shadow-sm d-flex align-items-center justify-content-between" style="border-radius: 12px !important;">
            <div>
                <h6 class="mb-1 text-uppercase" style="font-size: 0.75rem; opacity: 0.8; font-weight: bold; letter-spacing: 0.5px;">Total Books</h6>
                <h3 class="mb-0 fw-bold">3</h3>
            </div>
            <i class="bi bi-box-seam fs-1 opacity-50"></i>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-3 bg-success text-white rounded shadow-sm d-flex align-items-center justify-content-between" style="border-radius: 12px !important;">
            <div>
                <h6 class="mb-1 text-uppercase" style="font-size: 0.75rem; opacity: 0.8; font-weight: bold; letter-spacing: 0.5px;">Total Users</h6>
                <h3 class="mb-0 fw-bold">2</h3>
            </div>
            <i class="bi bi-people fs-1 opacity-50"></i>
        </div>
    </div>
    <div class="col-md-4">
        <div class="p-3 bg-warning text-dark rounded shadow-sm d-flex align-items-center justify-content-between" style="border-radius: 12px !important;">
            <div>
                <h6 class="mb-1 text-uppercase" style="font-size: 0.75rem; opacity: 0.8; font-weight: bold; letter-spacing: 0.5px;">Total Orders</h6>
                <h3 class="mb-0 fw-bold">0</h3>
            </div>
            <i class="bi bi-cart fs-1 opacity-50"></i>
        </div>
    </div>
</div>

{# Ֆիլտրացում ըստ Կատեգորիաների #}
<div class="mb-5">
    <h5 class="text-muted mb-3"><i class="bi bi-filter-square-fill"></i> Filter by Category:</h5>
    <div class="d-flex flex-wrap gap-2">
        <a href="{{ path('app_home') }}" class="btn btn-outline-dark rounded-pill px-4 {% if not currentCategory %}active{% endif %}">
            All Products
        </a>
        {% for category in categories %}
            <a href="{{ path('app_home', {'category': category.id}) }}" 
               class="btn btn-outline-primary rounded-pill px-4 {% if currentCategory == category.id %}active{% endif %}">
                 {{ category.name }}
            </a>
        {% endfor %}
    </div>
</div>

{# Ապրանքների Ցուցակ #}
<h2 class="mb-4 fw-bold text-secondary"><i class="bi bi-bag-heart-fill text-danger"></i> Featured Products</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
    {% for product in products %}
        <div class="col">
            <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 15px; overflow: hidden;">
                
                {% if product.image %}
                    <img src="{{ product.image }}" class="card-img-top" alt="{{ product.name }}" style="height: 250px; object-fit: cover;">
                {% else %}
                    <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500" class="card-img-top" alt="{{ product.name }}" style="height: 250px; object-fit: cover;">
                {% endif %}
                
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold m-0 text-dark">{{ product.name }}</h5>
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">${{ product.price }}</span>
                    </div>
                    
                    {% if product.category %}
                        <span class="badge bg-secondary mb-3"><i class="bi bi-tag-fill me-1"></i>{{ product.category.name }}</span>
                    {% endif %}
                    
                    <p class="card-text text-muted" style="font-size: 0.9rem;">{{ product.description }}</p>
                </div>
                
                <div class="card-footer bg-white border-top-0 p-4 pt-0">
                    <a href="{{ path('app_cart_add', {'id': product.id}) }}" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm">
                        <i class="bi bi-cart-plus-fill me-2"></i>Add to Cart
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12 text-center my-5">
            <div class="p-5 bg-white rounded shadow-sm">
                <i class="bi bi-emoji-frown display-1 text-muted"></i>
                <h3 class="mt-3 text-secondary">No products found</h3>
                <p class="text-muted">Go to Admin Panel and create some products first!</p>
            </div>
        </div>
    {% endfor %}
</div>

<style>
    .transition-hover { transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out; }
    .transition-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
</style>
{% endblock %}