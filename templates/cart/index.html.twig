{% extends 'base.html.twig' %}

{% block title %}Your Shopping Cart{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4 fw-bold"><i class="bi bi-cart3 text-primary"></i> Your Shopping Cart</h1>

    {% if items|length > 0 %}
        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-sm border-0 p-4" style="border-radius: 15px;">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Book</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                {% if item.product.image %}
                                                    <img src="{{ item.product.image }}" alt="{{ item.product.name }}" class="rounded me-3" style="width: 50px; height: 70px; object-fit: cover;">
                                                {% endif %}
                                                <div>
                                                    <h6 class="fw-bold m-0">{{ item.product.name }}</h6>
                                                    <small class="text-muted">
                                                        {{ item.product.category ? item.product.category.name : 'No category' }}
                                                    </small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>${{ item.product.price }}</td>
                                        <td>
                                            <span class="badge bg-secondary p-2 fs-6">{{ item.quantity }}</span>
                                        </td>
                                        <td class="fw-bold">${{ item.product.price * item.quantity }}</td>
                                        <td>
                                            <a href="{{ path('app_cart_remove', {'id': item.product.id}) }}" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                                <i class="bi bi-trash-fill"></i> Remove
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-4 bg-light" style="border-radius: 15px;">
                    <h4 class="fw-bold mb-4">Order Summary</h4>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Items Count:</span>
                        <span class="fw-bold">{{ items|length }}</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fs-5">Total Price:</span>
                        <span class="fs-4 fw-bold text-success">${{ total }}</span>
                    </div>
                    <button class="btn btn-success w-100 rounded-pill py-3 fw-bold shadow">
                        <i class="bi bi-credit-card-2-front-fill me-2"></i>Proceed to Checkout
                    </button>
                </div>
            </div>
        </div>
    {% else %}
        <div class="text-center py-5 bg-white rounded shadow-sm">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-3 text-secondary">Your cart is empty</h3>
            <p class="text-muted">Go back to the homepage and add some amazing books!</p>
            <a href="{{ path('app_home') }}" class="btn btn-primary rounded-pill px-4 py-2 mt-3 fw-bold">
                <i class="bi bi-arrow-left me-2"></i>Back to Shop
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}